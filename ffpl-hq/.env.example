# Copy this file to .env and fill in values for your environment.
# Never commit .env to source control.

# PocketBase instance URL
# Production: https://pb.ffplhq.com
VITE_PB_URL=http://127.0.0.1:8090

# Go automation server endpoints
# Production: https://api.ffplhq.com/queue-match
VITE_QUEUE_URL=http://localhost:8091/queue-match

# Shared API key — must match FFPL_API_KEY in server.env
VITE_API_KEY=changeme
